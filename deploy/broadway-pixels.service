[Unit]
Description=Broadway Pixels website
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/broadwaypixels
Environment=NODE_ENV=production
Environment=PORT=8080
EnvironmentFile=/etc/broadway-pixels.env
ExecStart=/usr/bin/node /var/www/broadwaypixels/server.mjs
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/var/www/broadwaypixels
ReadWritePaths=/var/lib/broadway-pixels

[Install]
WantedBy=multi-user.target
